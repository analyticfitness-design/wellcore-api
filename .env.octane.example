# Laravel Octane — production configuration example
# Copy relevant values to your .env on the production server.

OCTANE_SERVER=swoole
OCTANE_HTTPS=true
OCTANE_HOST=0.0.0.0
OCTANE_PORT=8000
OCTANE_WORKERS=auto
OCTANE_TASK_WORKERS=auto
OCTANE_MAX_REQUESTS=500

# Redis — replaces default drivers in production for high-performance caching
CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=null
